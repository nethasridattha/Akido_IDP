@using Microsoft.AspNetCore.Html
@model DTPortal.IDP.ViewModel.Login.LoginViewModel
@using System.Text.Json
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration


@{
    ViewData["Title"] = "Login";
    var name = Configuration["ProjectName"];
}

<link rel="stylesheet" href="~/assets/@name/appcss/LoginPage.css">
<style>
    .auth-box {
        background: none;
        border: none;
        padding: 0;
        margin: 0;
        font: inherit;
        text-align: left;
        cursor: pointer;
    }
</style>


<div id="overlay">
    <div class="cv-spinner">
        <span class="spinner">

        </span>
    </div>
</div>
<div id="overlay2">
    <div class="cv-spinner">
        <span class="spinner">

        </span>
    </div>
</div>
